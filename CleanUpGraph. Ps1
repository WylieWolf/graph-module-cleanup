foreach ($module in $modules) {
    Write-Host "=============================="
    Write-Host "Processing module: $module"
    Write-Host "=============================="

    # Check if installed via PowerShellGet
    $installedModule = Get-InstalledModule -Name $module -ErrorAction SilentlyContinue

    if ($installedModule) {
        Write-Host "Installed module found: $module"
        Get-InstalledModule -Name $module

        # Uninstall all versions
        Write-Host "Uninstalling all versions of $module..."
        Get-InstalledModule -Name $module | Uninstall-Module -AllVersions -Force
    }
    else {
        Write-Host "Module not found in Get-InstalledModule: $module"
    }

    # Check for any remaining available versions
    Write-Host "Checking locally available copies of $module..."
    Get-Module -Name $module -ListAvailable
    Write-Host ""
}
